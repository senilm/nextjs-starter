# ──────────────────────────────────────
# DATABASE
# ──────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/shipstation"

# ──────────────────────────────────────
# AUTHENTICATION (Better Auth)
# ──────────────────────────────────────
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ──────────────────────────────────────
# OAUTH PROVIDERS
# ──────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ──────────────────────────────────────
# PAYMENT PROVIDER
# ──────────────────────────────────────
PAYMENT_PROVIDER="stripe"

# ──────────────────────────────────────
# STRIPE (required when PAYMENT_PROVIDER=stripe)
# ──────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ──────────────────────────────────────
# RAZORPAY (required when PAYMENT_PROVIDER=razorpay)
# ──────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_WEBHOOK_SECRET=""

# ──────────────────────────────────────
# EMAIL (SMTP)
# ──────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="ShipStation <noreply@yourdomain.com>"

# ──────────────────────────────────────
# FILE UPLOADS (AWS S3)
# ──────────────────────────────────────
AWS_S3_BUCKET=""
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ──────────────────────────────────────
# APP CONFIG
# ──────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ShipStation"
